{
  "compilerOptions": {
    "module": "preserve",
    "esModuleInterop": true,
    "target": "esnext",
    "moduleResolution": "bundler",
    "removeComments": true,
    "sourceMap": false,

    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true,

    "skipLibCheck": true,
    "allowJs": true,

    "strict": false,
    "types": ["bun"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist/*", "src/static"],
  "lib": ["esnext"]
}